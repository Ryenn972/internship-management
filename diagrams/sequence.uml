@startuml Sequence diagram
title Diagramme de séquence - Gestion candidature stage

actor Etudiant
actor Responsable

participant "Interface Utilisateur" as UI #64B5F6
participant "Couche Métier" as Metier #81C784
database "Base de Données" as DB #FFB74D

== Consultation des offres ==
Etudiant -> UI : consulterOffres()
UI -> Metier : getOffres()
Metier -> DB : selectOffres()
DB --> Metier : listeOffres
Metier --> UI : listeOffres
UI --> Etudiant : afficherOffres

== Dépôt candidature ==
Etudiant -> UI : soumettreCandidature()

opt Utilisateur non connecté
    UI -> Etudiant : demanderConnexion
    Etudiant -> UI : saisirLogin(mdp)
    UI -> Metier : verifierLogin()
    Metier -> DB : getUser()

    alt Identifiants invalides
        DB --> Metier : null
        Metier --> UI : erreurConnexion
        UI --> Etudiant : afficherErreur
    else Identifiants valides
        DB --> Metier : user
        Metier --> UI : connexionOK
    end
end

UI -> Metier : creerCandidature()
Metier -> DB : insertCandidature()
DB --> Metier : OK
Metier --> UI : candidatureEnregistree
UI --> Etudiant : confirmationDepot

== Traitement par responsable ==
Responsable -> UI : consulterCandidatures()
UI -> Metier : getCandidatures()
Metier -> DB : selectCandidatures()
DB --> Metier : liste
Metier --> UI : liste
UI --> Responsable : afficherCandidatures

Responsable -> UI : validerOuRefuser()
UI -> Metier : updateStatut()
Metier -> DB : updateCandidature()
DB --> Metier : OK

alt Candidature validée
    Metier -> DB : creerNotification()
    Metier --> UI : notifierEtudiant
    Metier --> UI : notifierEntreprise
else Candidature refusée
    Metier -> DB : creerNotificationRefus()
    Metier --> UI : notifierEtudiant
end

@enduml